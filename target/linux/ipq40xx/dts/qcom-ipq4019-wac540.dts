/dts-v1/;

#include "qcom-ipq4019.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/soc/qcom,tcsr.h>
#include <dt-bindings/leds/common.h>

/ {
	model = "NETGEAR WAC540";
	compatible = "netgear,wac540", "qcom,ipq4019";

	aliases {
		ethernet0 = &gmac;
		led-boot = &led_power_blue;
		led-failsafe = &led_power_amber;
		led-upgrade = &led_power_amber;
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	soc {
		counter@4a1000 {
			compatible = "qcom,qca-gcnt";
			reg = <0x4a1000 0x4>;
		};

		tcsr@1949000 {
			compatible = "qcom,tcsr";
			reg = <0x1949000 0x100>;
			qcom,wifi_glb_cfg = <TCSR_WIFI_GLB_CFG>;
		};

		ess_tcsr@1953000 {
			compatible = "qcom,tcsr";
			reg = <0x1953000 0x1000>;
			qcom,ess-interface-select = <TCSR_ESS_PSGMII>;
		};

		tcsr@1957000 {
			compatible = "qcom,tcsr";
			reg = <0x1957000 0x100>;
			qcom,wifi_noc_memtype_m0_m2 = <TCSR_WIFI_NOC_MEMTYPE_M0_M2>;
		};
	};

	keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			gpios = <&tlmm 18 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
		};
	};

	leds {
		compatible = "gpio-leds";

		led_power_blue: power_blue {
			label = "blue:power";
			gpios = <&tlmm 4 GPIO_ACTIVE_HIGH>;
		};

		led_power_amber: power_amber {
			label = "amber:power";
			gpios = <&tlmm 5 GPIO_ACTIVE_HIGH>;
		};
	};
};

&blsp1_uart1 {
	status = "okay";
};

&watchdog {
	status = "okay";
};

&prng {
	status = "okay";
};

&crypto {
	status = "okay";
};

&cryptobam {
	status = "okay";
};

&gmac {
	status = "okay";
};

/* Activeer de interne Qualcomm DSA switch controller */
&switch {
	status = "okay";
};

/* Activeer de fysieke LAN poort 1 */
&swport4 {
	status = "okay";
	label = "lan1";
};

/* Activeer de fysieke LAN poort 2 */
&swport5 {
	status = "okay";
	label = "lan2";
};

&qpic_bam {
	status = "okay";
};

&nand {
	status = "okay";
	pinctrl-0 = <&nand_pins>;
	pinctrl-names = "default";

	nandflash@0 {
		reg = <0>;
		compatible = "qcom,nandflash";
        
		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "0:SBL1";
				reg = <0x00000000 0x00100000>;
				read-only;
			};

			partition@100000 {
				label = "0:MIBIB";
				reg = <0x00100000 0x00100000>;
				read-only;
			};

			partition@200000 {
				label = "0:QSEE";
				reg = <0x00200000 0x00100000>;
				read-only;
			};

			partition@300000 {
				label = "0:CDT";
				reg = <0x00300000 0x00080000>;
				read-only;
			};

			partition@380000 {
				label = "0:APPSBLENV";
				reg = <0x00380000 0x00080000>;
				read-only;
			};

			partition@400000 {
				label = "0:APPSBL";
				reg = <0x00400000 0x00200000>;
				read-only;
			};

			partition@600000 {
				label = "0:ART";
				reg = <0x00600000 0x00100000>;
				read-only;
			};

			/* 
			 * SAFELY CLAMPED FIRMWARE REGION:
			 * Truncated from 0x0f900000 to 0x05000000.
			 * Stops scanning cleanly at 0x05700000, 
			 * avoiding the bad blocks starting at 0x050e0000.
			 */
			partition@700000 {
				label = "firmware";
				reg = <0x00700000 0x05000000>;
				compatible = "ubi";
			};
		};
	};
};

&tlmm {
	mdio_pins: mdio_pinmux {
		mux_1 {
			pins = "gpio6";
			function = "mdio";
			bias-pull-up;
		};

		mux_2 {
			pins = "gpio7";
			function = "mdc";
			bias-pull-up;
		};
	};

	nand_pins: nand-pins {
		pins = "gpio53", "gpio54", "gpio55", "gpio56",
		       "gpio57", "gpio58", "gpio59", "gpio60",
		       "gpio61", "gpio62", "gpio63", "gpio64",
		       "gpio65", "gpio66", "gpio67", "gpio68",
		       "gpio69";
		function = "qpic";
		drive-strength = <10>;
		bias-disable;
	};
};

&mdio {
	status = "okay";

	pinctrl-0 = <&mdio_pins>;
	pinctrl-names = "default";
	reset-gpios = <&tlmm 62 GPIO_ACTIVE_LOW>;
	reset-delay-us = <2000>;
};

/* Interne QCA4019 Wi-Fi (2.4GHz) */
&wifi0 {
	status = "okay";
	qcom,ath10k-calibration-variant = "NETGEAR-WAC540";
};

/* Interne QCA4019 Wi-Fi (5GHz Low-band) */
&wifi1 {
	status = "okay";
	qcom,ath10k-calibration-variant = "NETGEAR-WAC540";
};

/* Externe QCA9984 Wi-Fi via PCIe (5GHz High-band) */
&pcie0 {
	status = "okay";
	bridge@0,0 {
		reg = <0x00000000 0 0 0 0>;
		#address-cells = <3>;
		#size-cells = <2>;
		ranges;
		wifi2: wifi@0,0 {
			compatible = "qcom,ath10k";
			reg = <0x00000000 0 0 0 0>;
			qcom,ath10k-calibration-variant = "NETGEAR-WAC540";
		};
	};
};

